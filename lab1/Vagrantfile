# -*- mode: ruby -*-
# vi: set ft=ruby :

# Вся конфигурация Vagrant выполняется ниже. "2" в Vagrant.configure
# определяет версию конфигурации (мы поддерживаем старые стили для
# обратной совместимости). Пожалуйста, не меняйте это, если вы не понимаете,
# что делаете.
# Vagrant.configure("2") do |config|
  # Наиболее распространенные параметры конфигурации задокументированы и закомментированы ниже.
  # Для получения полной информации, пожалуйста, обратитесь к онлайн-документации
  # по адресу https://docs.vagrantup.com.

  # Каждое окружение разработки Vagrant требует box. Вы можете искать
  # box на сайте https://vagrantcloud.com/search.
  # config.vm.box = "hashicorp/bionic64"

  # Отключить автоматическую проверку обновлений box. Если вы отключите это, то
  # box будут проверяться на наличие обновлений только при выполнении пользователем
  # команды `vagrant box outdated`. Это не рекомендуется.
  # config.vm.box_check_update = false

  # Создает проброс портов, который обеспечивает доступ к определенному порту
  # внутри виртуальной машины с порта на хост-машине. В примере ниже
  # обращение к "localhost:8080" обеспечит доступ к порту 80 гостевой машины.
  # ПРИМЕЧАНИЕ: Это обеспечит публичный доступ к открытому порту
  # config.vm.network "forwarded_port", guest: 80, host: 8080
  # config.vm.network "forwarded_port", guest: 80, host: 4567
  # Создает проброс портов, который обеспечивает доступ к определенному порту
  # внутри виртуальной машины с порта на хост-машине и разрешает доступ только
  # через 127.0.0.1 для предотвращения публичного доступа
  # config.vm.network "forwarded_port", guest: 80, host: 8080, host_ip: "127.0.0.1"

  # Создает частную сеть, которая обеспечивает доступ к машине только с хоста
  # с использованием определенного IP.
  # config.vm.network "private_network", ip: "192.168.33.10"

  # Создает публичную сеть, которая обычно соответствует мостовой сети.
  # Мостовые сети делают машину видимой как другое физическое устройство в
  # вашей сети.
  # config.vm.network "public_network"
  # config.vm.network "public_network", ip: "192.168.88.80"
  # Пробрасывает дополнительную папку в гостевую ВМ. Первый аргумент -
  # это путь к реальной папке на хост-машине. Второй аргумент -
  # это путь в гостевой системе для монтирования папки. И третий, необязательный
  # аргумент - это набор необязательных параметров.
  # config.vm.synced_folder "../data", "/vagrant_data"

  # Отключает общую папку по умолчанию для текущего каталога с кодом. Это действие
  # обеспечивает лучшую изоляцию между vagrant box и вашим хостом,
  # гарантируя, что ваш Vagrantfile не будет доступен изнутри vagrant box.
  # Если вы используете это, вы, возможно, захотите включить дополнительные общие подпапки, как
  # показано выше.
  # config.vm.synced_folder ".", "/vagrant", disabled: true

  # Конфигурация, специфичная для провайдера, чтобы вы могли точно настроить различные
  # нижележащие провайдеры для Vagrant. Здесь указываются специфичные для провайдера параметры.
  # Пример для VirtualBox:
  #
  # config.vm.provider "virtualbox" do |vb|
  #   # Показывать графический интерфейс VirtualBox при загрузке машины
  #   vb.gui = true
  #
  #   # Оперативная память задается в мегабайтах VM:
    # vb.memory = "2024"
    # ядра вм
    #vb.cpus = 2
   #end
  #
  # Обратитесь к документации по используемому провайдеру для получения дополнительной
  # информации о доступных параметрах.

  # Включение настройки (провижининга) с помощью shell-скрипта. Также доступны другие средства
  # настройки, такие как Ansible, Chef, Docker, Puppet и Salt. Пожалуйста, обратитесь к
  # документации для получения дополнительной информации об их специфическом синтаксисе и использовании.
  # config.vm.provision "shell", inline: <<-SHELL
  #   apt-get update
  #   apt-get install -y apache2
  # SHELL
Vagrant.configure("2") do |config|
  # Общие настройки (действуют на все машины, если не переопределены)
  config.vm.box = "hashicorp/bionic64"

  # Описание первой машины
  config.vm.define "vm1" do |web|
    web.vm.hostname = "vm1-host"
    web.vm.network "public_network", ip: "192.168.88.80"

    web.vm.provider "virtualbox" do |v|
      v.memory = 2048
      v.cpus = 2
    end
  end

  # Описание второй машины
  config.vm.define "vm2" do |db|
    db.vm.hostname = "vm2-host"
    db.vm.network "public_network", ip: "192.168.88.81"

    db.vm.provider "virtualbox" do |v|
      v.memory = 2048
      v.cpus = 2
    end
  end
end


#end